# Git Submodules for Tuxbox-OS Builder
#
# To initialize all submodules after cloning:
#   git submodule update --init --recursive
#
# Submodules are pinned to specific commits for reproducibility
# OE-Alliance: branch 4.0 (Yocto Kirkstone), commit 6b5d3901ecc757e5dadb6d8c95430334532f8960
# meta-neutrino: kirkstone-migration branch (migrated to Kirkstone), commit 9ee3484c5f569d6a14a775e2ee0ae97346cb44be
# Poky: branch kirkstone (Yocto 4.0 LTS)
# meta-openembedded: branch kirkstone (Yocto 4.0 LTS)
[submodule "oe-alliance"]
	path = oe-alliance
	url = https://github.com/oe-alliance/oe-alliance-core.git
	branch = 4.0
[submodule "meta-neutrino"]
	path = meta-neutrino
	url = https://github.com/tuxbox-neutrino/meta-neutrino.git
[submodule "poky"]
	path = poky
	url = https://git.yoctoproject.org/git/poky
	branch = kirkstone
[submodule "meta-openembedded"]
	path = meta-openembedded
	url = https://git.openembedded.org/meta-openembedded
	branch = kirkstone
